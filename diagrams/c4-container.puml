@startuml C4-Container-Marketplace
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title C4 Container — Marketplace (упрощённо)

Person(buyer,  "Покупатель")
Person(seller, "Продавец")

System_Boundary(mp, "Marketplace") {

    Container(web, "Web / Mobile App", "", "Клиент")
    Container(gw,  "API Gateway", "FastAPI", "Точка входа *(поднимается в этом ДЗ)*")

    Container(identity,   "Identity",    "", "Пользователи, роли *(своя БД)*")
    Container(catalog,    "Catalog",     "", "Товары, остатки, цены *(своя БД)*")
    Container(feed,       "Search & Feed", "", "Поиск и лента *(свои хранилища)*")
    Container(order,      "Ordering",    "", "Корзина, заказы *(своя БД)*")
    Container(payment,    "Payments",    "", "Платежи, выплаты *(своя БД, PCI)*")
    Container(notify,     "Notifications", "", "Отправка уведомлений *(своя БД)*")

    ContainerQueue(bus, "Kafka", "", "Обмен событиями между доменами")
}

System_Ext(psp,   "Payment Provider", "")
System_Ext(ch, "Каналы уведомлений", "Email / Push / SMS провайдеры")

Rel(buyer,  web, "HTTPS")
Rel(seller, web, "HTTPS")
Rel(web, gw, "HTTPS / REST")

Rel(gw, identity, "прокси", "sync REST/gRPC")
Rel(gw, catalog,  "прокси", "sync")
Rel(gw, feed,     "прокси", "sync")
Rel(gw, order,    "прокси", "sync")
Rel(gw, payment,  "прокси", "sync")

Rel(catalog, bus, "события", "Kafka")
Rel(order,   bus, "события", "Kafka")
Rel(bus, feed, "события", "Kafka")
Rel(bus, notify, "события", "Kafka")

Rel(payment, psp, "списание / выплаты", "HTTPS")
Rel(notify, ch, "доставка", "HTTPS/API")

Rel(order, catalog, "резерв остатка", "sync gRPC")

note right of mp
    У каждого сервиса **своя БД**.
    Никаких shared DB между сервисами.
    Детали владения данными см. README → §7.
end note

@enduml
