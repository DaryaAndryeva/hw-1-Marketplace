@startuml C4-Container-Marketplace
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C4 Container - Marketplace

Person(buyer, "Покупатель")
Person(seller, "Продавец")

System_Boundary(mp, "Marketplace") {

    Container(web, "Web / приложение", "React / Mobile", "")
    Container(gw, "API Gateway", "FastAPI", "")

    Container(users, "Users", "", "")
    Container(catalog, "Catalog", "", "")
    Container(recs, "Recommendations", "", "")
    Container(orders, "Orders", "", "")
    Container(payments, "Payments", "", "")
    Container(notify, "Notifications", "", "")

}

System_Ext(psp, "Payment provider")
System_Ext(ch, "Email / Push / SMS")

Rel(buyer, web, "HTTPS")
Rel(seller, web, "HTTPS")
Rel(web, gw, "REST")

Rel(gw, users, "REST")
Rel(gw, catalog, "REST")
Rel(gw, recs, "REST")
Rel(gw, orders, "REST")
Rel(gw, payments, "REST")
Rel(gw, notify, "REST")

Rel(recs, catalog, "REST")
Rel(recs, users, "REST")
Rel(orders, catalog, "REST")
Rel(orders, payments, "REST")
Rel(orders, notify, "REST")

Rel(payments, psp, "HTTPS")
Rel(notify, ch, "HTTPS")

@enduml
